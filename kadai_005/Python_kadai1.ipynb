        "# 変数の入力\n",
        "top = 10\n",
        "bottom = 20\n",
        "height = 5\n",
        "\n",
        "# 変数を埋め込んで面積を計算\n",
        "area = (top + bottom) * height / 2\n",
        "\n",
        "# 計算結果を文字列内に埋め込んで面積を表示\n",
        "print(f\"{area}㎠\")"
      ]
